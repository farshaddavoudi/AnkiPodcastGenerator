{
  "Anki": {
    "BaseUrl": "http://127.0.0.1:8765",
    "SyncBeforeQuery": true
  },
  "Podcast": {
    "OutputFolder": "C:\\AnkiPodcasts",
    "GenerationProfile": "QualityLocalTts",
    "ScriptProvider": "AvalAi",
    "TextToSpeechProvider": "AvalAi",
    "TargetMinutes": 30,
    "ReuseIfSameCards": true,
    "MultiSpeaker": true
  },
  "GenerationProfiles": {
    "Quality": {
      "Description": "Highest quality, highest API cost. Uses Claude Sonnet for the script and Gemini Flash TTS.",
      "ScriptProvider": "AvalAi",
      "TextToSpeechProvider": "AvalAi",
      "ScriptModel": "claude-sonnet-4-6",
      "TtsModel": "gemini-2.5-flash-tts",
      "TtsFallbackModel": "",
      "VoiceA": "Kore",
      "VoiceB": "Algenib",
      "TtsSpeed": 1.0,
      "MultiSpeaker": true
    },
    "QualityLocalTts": {
      "Description": "High-quality Claude Sonnet script generation with local Kokoro TTS.",
      "ScriptProvider": "AvalAi",
      "TextToSpeechProvider": "Kokoro",
      "ScriptModel": "claude-sonnet-4-6",
      "TtsModel": "kokoro-v1.0",
      "VoiceA": "af_kore",
      "VoiceB": "am_puck",
      "TtsSpeed": 1.0,
      "MultiSpeaker": true
    },
    "Balanced": {
      "Description": "Lower script-generation cost while keeping the current high-quality Gemini TTS path.",
      "ScriptProvider": "AvalAi",
      "TextToSpeechProvider": "AvalAi",
      "ScriptModel": "gemini-2.5-flash",
      "TtsModel": "gemini-2.5-flash-tts",
      "TtsFallbackModel": "",
      "VoiceA": "Kore",
      "VoiceB": "Algenib",
      "TtsSpeed": 1.0,
      "MultiSpeaker": true
    },
    "LocalTts": {
      "Description": "Balanced script generation with local Kokoro TTS. Requires kokoro-tts and model files installed first.",
      "ScriptProvider": "AvalAi",
      "TextToSpeechProvider": "Kokoro",
      "ScriptModel": "gemini-2.5-flash",
      "TtsModel": "kokoro-v1.0",
      "VoiceA": "af_kore",
      "VoiceB": "am_puck",
      "TtsSpeed": 1.0,
      "MultiSpeaker": true
    },
    "BudgetLocalTts": {
      "Description": "Cheapest mode. Uses Gemini Flash-Lite for scripts and local Kokoro TTS.",
      "ScriptProvider": "AvalAi",
      "TextToSpeechProvider": "Kokoro",
      "ScriptModel": "gemini-2.5-flash-lite-preview-09-2025",
      "TtsModel": "kokoro-v1.0",
      "VoiceA": "af_kore",
      "VoiceB": "am_puck",
      "TtsSpeed": 1.0,
      "MultiSpeaker": true
    },
    "GemmaOpenRouterLocalTts": {
      "Description": "Experimental free OpenRouter Gemma script generation with local Kokoro TTS.",
      "ScriptProvider": "OpenRouter",
      "TextToSpeechProvider": "Kokoro",
      "ScriptModel": "google/gemma-4-31b-it:free",
      "TtsModel": "kokoro-v1.0",
      "VoiceA": "af_kore",
      "VoiceB": "am_puck",
      "TtsSpeed": 1.0,
      "MultiSpeaker": true
    }
  },
  "AvalAi": {
    "BaseUrl": "https://api.avalai.ir",
    "ApiKey": "",
    "ScriptModel": "claude-sonnet-4-6",
    "TtsModel": "gemini-2.5-flash-tts",
    "TtsFallbackModel": "",
    "VoiceA": "Kore",
    "VoiceB": "Algenib",
    "TtsSpeed": 1.0
  },
  "Kokoro": {
    "Command": "kokoro-tts",
    "WorkingDirectory": "",
    "ModelName": "kokoro-v1.0",
    "Language": "en-us",
    "TimeoutSeconds": 900
  },
  "OpenRouter": {
    "BaseUrl": "https://openrouter.ai/api/v1",
    "ApiKey": "",
    "Referer": "https://github.com/fdavo/AnkiPodcastGenerator",
    "Title": "AnkiPodcastGenerator"
  },
  "Decks": [
    {
      "DeckName": "Career::DevOps",
      "MaxCards": 10
    },
    {
      "DeckName": "Career::ApSwe",
      "MaxCards": 10
    },
    {
      "DeckName": "Language::English",
      "MaxCards": 40
    }
  ],
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/anki-podcast-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  }
}
