{
  "Anki": {
    "BaseUrl": "http://127.0.0.1:8765",
    "SyncBeforeQuery": true
  },
  "Podcast": {
    "OutputFolder": "C:\\AnkiPodcasts",
    "TargetMinutes": 30,
    "ReuseIfSameCards": true,
    "MultiSpeaker": true
  },
  "AvalAi": {
    "BaseUrl": "https://api.avalai.ir",
    "ApiKey": "",
    "ScriptModel": "claude-sonnet-4-5",
    "TtsModel": "gemini-2.5-flash-tts",
    "TtsFallbackModel": "",
    "VoiceA": "Kore",
    "VoiceB": "Algenib",
    "TtsSpeed": 1.0
  },
  "Decks": [
    {
      "DeckName": "Career::DevOps",
      "MaxCards": 10
    },
    {
      "DeckName": "Career::ApSwe",
      "MaxCards": 10
    },
    {
      "DeckName": "English",
      "MaxCards": 40
    }
  ],
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/anki-podcast-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  }
}
