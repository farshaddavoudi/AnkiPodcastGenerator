{
  "Anki": {
    "BaseUrl": "http://127.0.0.1:8765",
    "SyncBeforeQuery": true
  },
  "Podcast": {
    "OutputFolder": "C:\\AnkiPodcasts",
    "TargetMinutes": 30,
    "MaxCards": 40,
    "ReuseIfSameCards": true,
    "MultiSpeaker": true
  },
  "AvalAi": {
    "BaseUrl": "https://api.avalai.ir",
    "ApiKey": "",
    "ScriptModel": "claude-sonnet-4-5",
    "TtsModel": "gemini-2.5-flash-tts",
    "TtsFallbackModel": "",
    "VoiceA": "Kore",
    "VoiceB": "Algenib",
    "TtsSpeed": 1.0
  },
  "Profiles": [
    {
      "Name": "DailyDevOps",
      "AnkiQuery": "deck:\"Career::DevOps\" is:due",
      "TargetMinutes": 30,
      "MaxCards": 10,
      "MultiSpeaker": true,
      "OutputSlug": "devops"
    },
    {
      "Name": "DailyApSwe",
      "AnkiQuery": "deck:\"Career::ApSwe\" is:due",
      "TargetMinutes": 30,
      "MaxCards": 10,
      "MultiSpeaker": true,
      "OutputSlug": "apswe"
    },
    {
      "Name": "DailyEnglish",
      "AnkiQuery": "deck:English is:due",
      "TargetMinutes": 30,
      "MaxCards": 40,
      "OutputSlug": "english"
    },
    {
      "Name": "TripMode",
      "AnkiQuery": "is:due",
      "TargetMinutes": 120,
      "MaxCards": 200,
      "OutputSlug": "tripmode"
    }
  ],
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/anki-podcast-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  }
}
